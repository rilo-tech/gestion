# Do not set NODE_ENV=production while running `npm run dev` locally.
# If NODE_ENV is production, Vite can emit an empty client bundle (blank page).

# ─── Desarrollo local (emulador) ───
USE_FIRESTORE_EMULATOR=true
FIREBASE_PROJECT_ID=rilo-7eff4
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Bucket de Storage (producción). Por defecto: {FIREBASE_PROJECT_ID}.firebasestorage.app
# Activá Storage en Firebase Console y ejecutá: firebase deploy --only storage
# FIREBASE_STORAGE_BUCKET=rilo-7eff4.firebasestorage.app

# .env va en la RAÍZ del repo (gestion/.env), no en frontend/
VITE_FIREBASE_PROJECT_ID=rilo-7eff4
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=rilo-7eff4.firebaseapp.com
# En producción (Firebase Hosting estático), apuntá al backend publicado (Cloud Run / Functions).
# Ejemplo: https://gestion-api-xxxxx-uc.a.run.app
VITE_API_BASE_URL=
# true = emulador local (npm run emulators en otra terminal). false = Google real.
VITE_USE_FIREBASE_AUTH_EMULATOR=true

# No uses GOOGLE_APPLICATION_CREDENTIALS con emulador
# GOOGLE_APPLICATION_CREDENTIALS=

PLATFORM_ADMIN_USER=superadmin
PLATFORM_ADMIN_PASSWORD=superadmin
PLATFORM_ADMIN_EMAIL=tu-email@gmail.com

JWT_SECRET=change-me-in-production-use-long-random-string
SKIP_DEFAULT_BUSINESS=true

APP_URL=http://localhost:3000
# Registro autoservicio — envío real en local (Resend, plan gratis ~3000/mes)
TRIAL_EMAIL_SEND_IN_DEV=true
RESEND_API_KEY=re_xxxxxxxx
# Con onboarding@resend.dev solo podés enviar al email de tu cuenta Resend
TRIAL_EMAIL_FROM=RILO Gestión <onboarding@resend.dev>
# Si el envío falla o no hay API key, muestra el código en pantalla / consola
TRIAL_OTP_DEV_MODE=true
TRIAL_EMAIL_DEV_MODE=true
TRIAL_DEFAULT_PLAN_ID=plan_intermedio
# WhatsApp de soporte (opcional, para pantallas públicas)
VITE_SUPPORT_WHATSAPP_URL=https://wa.me/59800000000
GEMINI_API_KEY=
# RiloBot / Meta WhatsApp webhook (desarrollo local)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=rilo-dev-verify

# ─── Producción (Firebase real) ───
# USE_FIRESTORE_EMULATOR=false
# GOOGLE_APPLICATION_CREDENTIALS=credentials/rilo-7eff4-firebase-adminsdk.json
# VITE_USE_FIREBASE_AUTH_EMULATOR=false
# Luego: npm run bootstrap:production
