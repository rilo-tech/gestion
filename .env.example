# Do not set NODE_ENV=production while running `npm run dev` locally.
# If NODE_ENV is production, Vite can emit an empty client bundle (blank page).

# ─── Desarrollo local (emulador) ───
USE_FIRESTORE_EMULATOR=true
FIREBASE_PROJECT_ID=rilo-7eff4
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# .env va en la RAÍZ del repo (gestion/.env), no en frontend/
VITE_FIREBASE_PROJECT_ID=rilo-7eff4
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=rilo-7eff4.firebaseapp.com
# true = emulador local (npm run emulators en otra terminal). false = Google real.
VITE_USE_FIREBASE_AUTH_EMULATOR=true

# No uses GOOGLE_APPLICATION_CREDENTIALS con emulador
# GOOGLE_APPLICATION_CREDENTIALS=

PLATFORM_ADMIN_USER=superadmin
PLATFORM_ADMIN_PASSWORD=superadmin
PLATFORM_ADMIN_EMAIL=tu-email@gmail.com

JWT_SECRET=change-me-in-production-use-long-random-string
SKIP_DEFAULT_BUSINESS=true

APP_URL=http://localhost:3000
GEMINI_API_KEY=

# ─── Producción (Firebase real) ───
# USE_FIRESTORE_EMULATOR=false
# GOOGLE_APPLICATION_CREDENTIALS=credentials/rilo-7eff4-firebase-adminsdk.json
# VITE_USE_FIREBASE_AUTH_EMULATOR=false
# Luego: npm run bootstrap:production
